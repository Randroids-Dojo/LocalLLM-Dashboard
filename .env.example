# Neon Postgres (Vercel Marketplace integration injects these).
DATABASE_URL=
# Direct (unpooled) URL — migrations only.
DATABASE_URL_UNPOOLED=

# Upstash Redis (Vercel Marketplace) — rate-limit counters only. Either naming works.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# App-owned secrets (set manually with `vercel env add`).
DASHBOARD_ADMIN_TOKEN=   # >=16 chars; gates /api/admin/* and /privacy removal
SUBMISSION_HMAC_SECRET=  # also embedded in the open-source app (speed-bump, not a gate)
IP_HASH_SALT=            # salt for hashing client IPs (privacy)

# Optional: archive raw evidence (events.log/test-output.txt) to Vercel Blob.
BLOB_READ_WRITE_TOKEN=

# Public base URL used by the macOS app's "Open Dashboard" deep link (docs only).
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000
